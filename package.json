{
  "name": "nyxfile",
  "version": "1.0.0",
  "description": "Nyxfile - AI-powered file manager with chat interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "build": {
    "appId": "com.nyxfile.app",
    "productName": "Nyxfile",
    "publish": null,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "icons/icon.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "icons/icon.png",
      "category": "public.app-category.utilities",
      "hardenedRuntime": false,
      "artifactName": "Nyxfile-${version}-${arch}.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "ai/**/*",
      "node_modules/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "openai": "^4.70.0"
  }
}
